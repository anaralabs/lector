{
  "name": "lector-monorepo",
  "version": "0.0.0",
  "description": "Headless PDF viewer for React",
  "author": "andrewdr (https://github.com/andrewdoro)",
  "type": "module",
  "private": "true",
  "scripts": {
    "build": "turbo run build ",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "prepare": "husky",
    "test": "turbo run test",
    "dev": "turbo run dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@commitlint/config-conventional": "^19.6.0",
    "commitlint": "^19.6.1",
    "turbo": "^2.9.14"
  },
  "keywords": [
    "pdf",
    "react",
    "headless",
    "viewer",
    "react-pdf",
    "anaralabs",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/anaralabs/lector.git"
  },
  "bugs": {
    "url": "https://github.com/anaralabs/lector/issues"
  },
  "homepage": "https://github.com/anaralabs/lector",
  "packageManager": "pnpm@9.5.0",
  "dependencies": {
    "husky": "^9.1.7",
    "semantic-release": "^24.2.0"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "type-enum": [
        2,
        "always",
        [
          "build",
          "chore",
          "ci",
          "clean",
          "doc",
          "feat",
          "fix",
          "perf",
          "ref",
          "revert",
          "style",
          "test"
        ]
      ],
      "subject-case": [
        0,
        "always",
        "sentence-case"
      ],
      "body-leading-blank": [
        2,
        "always",
        true
      ]
    }
  },
  "pnpm": {
    "overrides": {
      "brace-expansion@1": "^1.1.13",
      "brace-expansion@2": "^2.0.3",
      "fast-xml-parser": "^4.5.4",
      "handlebars": "^4.7.9",
      "@babel/helpers": "^7.26.10",
      "@babel/runtime": "^7.26.10",
      "@octokit/endpoint": "^10.1.3",
      "@octokit/plugin-paginate-rest": "^11.4.1",
      "@octokit/request-error": "^6.1.7",
      "@octokit/request": "^9.2.1",
      "ajv@8": "^8.18.0",
      "estree-util-value-to-estree": "^3.3.3",
      "js-yaml@3": "^3.14.2",
      "js-yaml@4": "^4.1.1",
      "lodash": "^4.18.0",
      "lodash-es": "^4.18.1",
      "mdast-util-to-hast": "^13.2.1",
      "picomatch@2": "^2.3.2",
      "picomatch@4": "^4.0.4",
      "postcss@8": "^8.5.10",
      "uuid": "^11.1.1",
      "ws@8": "^8.20.1",
      "yaml@2": "^2.8.3",
      "vite@5": "^6.4.3",
      "vite@6": "^6.4.3",
      "@babel/core": "^7.29.6",
      "socks": "^2.8.9"
    }
  }
}
